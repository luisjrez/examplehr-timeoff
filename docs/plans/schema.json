{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "examplehr-timeoff/plan.schema.json",
  "title": "Stateful multi-phase plan",
  "type": "object",
  "required": [
    "id",
    "title",
    "spec",
    "status",
    "createdAt",
    "updatedAt",
    "phases"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^plan-[0-9]{4}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "spec": {
      "type": "string",
      "description": "What drives this plan: TRD sections, issue URLs, or an inline goal statement.",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "approved", "in_progress", "completed", "abandoned"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "notes": {
      "type": "array",
      "description": "Decision log: why phases were reordered, skipped or the plan abandoned.",
      "items": { "type": "string" }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "goal",
          "dependsOn",
          "parallelizable",
          "status",
          "tasks",
          "acceptance"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^phase-[0-9]+$" },
          "title": { "type": "string", "minLength": 1 },
          "goal": { "type": "string", "minLength": 1 },
          "dependsOn": {
            "type": "array",
            "description": "Phase ids that must be completed before this phase is ready.",
            "items": { "type": "string", "pattern": "^phase-[0-9]+$" }
          },
          "parallelizable": {
            "type": "boolean",
            "description": "May run alongside other ready parallelizable phases (disjoint artifacts required)."
          },
          "status": {
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "blocked",
              "skipped"
            ]
          },
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "status", "verification"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string", "minLength": 1 },
                "status": {
                  "enum": ["pending", "in_progress", "completed", "skipped"]
                },
                "verification": {
                  "type": "string",
                  "description": "Command or observable criteria proving the task is done."
                }
              }
            }
          },
          "acceptance": {
            "type": "array",
            "description": "Phase-level done criteria, beyond individual tasks.",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "artifacts": {
            "type": "array",
            "description": "Files/areas this phase expects to touch — used to sanity-check parallelizability.",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
